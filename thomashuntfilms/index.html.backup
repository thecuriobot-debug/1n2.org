    <script>
        // Prevent auto-scroll on page load
        if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual';
        }
        
        // Handle hash navigation
        function showSection(e) {
            // Prevent default anchor scroll
            if (e) {
                e.preventDefault();
            }
            
            let hash = window.location.hash;
            
            // If no hash, randomly select a section
            if (!hash) {
                const sections = ['star-trek', 'star-wars', 'john-wick', 'movies', 'batman', 'other', 'ig-88', 'press'];
                const randomSection = sections[Math.floor(Math.random() * sections.length)];
                hash = '#' + randomSection;
                // Set the hash without triggering hashchange event
                history.replaceState(null, null, hash);
            }
            
            const sectionId = hash.substring(1);
            
            // Scroll to top FIRST
            window.scrollTo(0, 0);
            
            // Hide all sections
            document.querySelectorAll('.series-content').forEach(section => {
                section.classList.remove('active');
            });
            
            // Show target section
            const target = document.getElementById(sectionId);
            if (target) {
                target.classList.add('active');
            }
            
            // Update nav active state
            document.querySelectorAll('nav a').forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === hash) {
                    link.classList.add('active');
                }
            });
            
            // Force scroll to top again after render
            setTimeout(() => window.scrollTo(0, 0), 0);
        }
        
        // Prevent default hash navigation
        document.addEventListener('click', function(e) {
            if (e.target.tagName === 'A' && e.target.getAttribute('href').startsWith('#')) {
                e.preventDefault();
                window.location.hash = e.target.getAttribute('href');
            }
        });
        
        // Show correct section on hash change
        window.addEventListener('hashchange', showSection);
        
        // Show correct section on load
        window.addEventListener('load', function() {
            showSection();
            window.scrollTo(0, 0);
        });
        
        // Emergency scroll to top
        setTimeout(() => window.scrollTo(0, 0), 100);
    </script>
</body>
</html>
