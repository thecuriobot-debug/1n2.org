thunt-data-labs/.env
thunt-data-labs/.DS_Store
**/__pycache__/
*.pyc
**/.DS_Store

# Large media files - stored in ~/LargeData/ not in git
# See ~/LargeData/README.md for details
bitcoingroup-audio/audio/
bitcoingroup-audio/video/
**/*.m4a
**/*.mp4
**/*.mov
**/*.avi
**/*.mkv

# Node modules - never commit
**/node_modules/

# Large database files
**/*.db
**/*.sqlite
**/*.sqlite3

# Large JSON data files (regeneratable)
thunt-data-labs/db/*.db
thunt-data-labs/db/*.sqlite
thunt-data-labs/db/*.sqlite3
# database.py is tracked (NOT excluded)
dashboarder/data/comments.json
old-projects/reader/data/comments.json

# Old projects have their own separate repos
old-projects/
medialog/
