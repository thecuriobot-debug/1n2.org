s-2259311376.jpg?itok=bNuY0NZZ"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259311376.jpg?itok=PoBSNoVW","small":"2x1_small/public/GettyImages-2259311376.jpg?itok=GmlJYJrA","medium":"2x1_medium/public/GettyImages-2259311376.jpg?itok=cTl2fS1W","large":"2x1_large/public/GettyImages-2259311376.jpg?itok=0vo3Ikn-","full":"2x1_full/public/GettyImages-2259311376.jpg?itok=4Xe_rnz9"}}},"teaser_body":"The talks are unlikely to produce a near-term settlement, as Russia will continue to press its territorial demands while using diplomacy to manage sanctions pressure and build leverage ahead of a spring-summer offensive.","pov":"","mailout":"U.S.-brokered talks between Russia and Ukraine will likely continue, and to deliver limited confidence-building steps. But they are unlikely to produce a near-term settlement, as Russia will continue to press its territorial demands while using diplomacy to manage sanctions pressure and build leverage ahead of a spring-summer offensive.","overview":"","youtube_video_url":"","created":"1770405545","created_formatted":"Feb 6, 2026 | 19:19 GMT","changed":"1770406072","changed_formatted":"Feb 6, 2026 | 19:27 GMT","path_alias":"article/limits-russia-ukraine-us-talks","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"59","vid":"5","v_name":"countries","name":"United States","code":"US","path_alias":"/region/americas/united-states"},{"tid":"138","vid":"5","v_name":"countries","name":"United Arab Emirates","code":"AE","path_alias":"/region/middle-east-and-north-africa/united-arab-emirates"},{"tid":"113","vid":"5","v_name":"countries","name":"Ukraine","code":"UA","path_alias":"/region/eurasia/ukraine"},{"tid":"110","vid":"5","v_name":"countries","name":"Russia","code":"RU","path_alias":"/region/eurasia/russia"},{"tid":"529","vid":"33","v_name":"wv_topics","name":"Military \u0026 Security","path_alias":"/topic/military-security"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"},{"tid":"1840","vid":"33","v_name":"wv_topics","name":"Russia-Ukraine Conflict","path_alias":"/topic/russia-ukraine-conflict"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"59","vid":"5","name":"United States"},{"tid":"138","vid":"5","name":"United Arab Emirates"},{"tid":"113","vid":"5","name":"Ukraine"},{"tid":"110","vid":"5","name":"Russia"}],"wv_topics":[{"tid":"529","vid":"33","name":"Military \u0026 Security"},{"tid":"530","vid":"33","name":"Politics"},{"tid":"1840","vid":"33","name":"Russia-Ukraine Conflict"}],"is_bookmarked":0},{"nid":"351936","type":"article","ntype":"worldview","title":"Lessons Learned From Indonesia's Market Rout","promo_image":{"uri":"public://GettyImages-2258212948 (1).jpg","alt":"Visitors take pictures in front of an electronic board displaying falling stock prices at the Indonesia Stock Exchange in Jakarta on Jan. 29, 2026.","title":"Visitors take pictures in front of an electronic board displaying falling stock prices at the Indonesia Stock Exchange in Jakarta on Jan. 29, 2026.","caption":"Visitors take pictures in front of an electronic board displaying falling stock prices at the Indonesia Stock Exchange in Jakarta on Jan. 29, 2026.","credit":"(YASUYOSHI CHIBA / AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=paonbKCG","small":"16x9_small/public/GettyImages-2258212948%20%281%29.jpg?itok=HZXNR7N2","medium":"16x9_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=12Gl42M7","large":"16x9_large/public/GettyImages-2258212948%20%281%29.jpg?itok=MkzNtyoC","full":"16x9_full/public/GettyImages-2258212948%20%281%29.jpg?itok=xhVFtvCw"},"square":{"tiny":"square_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=27dRLCmW","small":"square_small/public/GettyImages-2258212948%20%281%29.jpg?itok=5gTXsTu_","medium":"square_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=734pUUqt","large":"square_large/public/GettyImages-2258212948%20%281%29.jpg?itok=7fw3unKh","full":"square_full/public/GettyImages-2258212948%20%281%29.jpg?itok=r5NP-X6Z"},"article":{"tiny":"article_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=CZ-ArUvP","small":"article_small/public/GettyImages-2258212948%20%281%29.jpg?itok=3Oyyd-Xi","medium":"article_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=qCor6Hs9","large":"article_large/public/GettyImages-2258212948%20%281%29.jpg?itok=qoVCixbi","full":"article_full/public/GettyImages-2258212948%20%281%29.jpg?itok=xXau38a4"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=VffYvvQ_","small":"2x1_small/public/GettyImages-2258212948%20%281%29.jpg?itok=8_ee7EGO","medium":"2x1_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=QuFQx3a4","large":"2x1_large/public/GettyImages-2258212948%20%281%29.jpg?itok=3FJ3Mm0f","full":"2x1_full/public/GettyImages-2258212948%20%281%29.jpg?itok=1MoQyNQE"}}},"teaser_body":"The episode exposes structural risks embedded in the president's governance that could threaten investor confidence -- and with it, Indonesia's economic growth and manufacturing competitiveness.","pov":"","mailout":"Indonesia's market rout has exposed deeper structural and governance vulnerabilities that now threaten investor confidence, complicate the government's investment-led growth strategy and raise risks to the country's competitiveness as a regional manufacturing hub. On Jan. 29, Indonesia's equity market sold off sharply after MSCI, a U.S.-based global index provider, raised concerns about the \"investability\" of Indonesian equities. MSCI cited opaque ownership structures, a small proportion of shares available for public trading and insufficient transparency around trading and shareholder data, and warned that Indonesia's equity market could be downgraded from \"emerging market\" to \"frontier market\" status if deficiencies were not addressed ahead of MSCI's scheduled May index review. Following the warning, the benchmark Jakarta Composite Index fell more than 8% over two consecutive trading days, including a steep intraday decline on Jan. 30 that triggered an automatic trading halt under exchange volatility rules. The selloff wiped out an estimated $80 billion in market capitalization before prices stabilized later in the day, following public statements and press briefings by the Ministry of Finance, Bank Indonesia, the Financial Services Authority and the Indonesia Stock Exchange outlining prospective regulatory and market support measures. At the same time, financial stress spilled into currency markets, causing the Indonesian rupiah to weaken by approximately 4%; the currency traded near record lows before stabilizing. The episode escalated further on Feb. 5 when Moody's Ratings cut Indonesia's sovereign credit rating outlook from \"stable\" to \"negative,\" citing lower policy predictability, rising fiscal pressures, weakening foreign reserves and debt risks linked to state-owned enterprises, broadening the episode from an equity market shock into an explicit warning about sovereign policy credibility. The market selloff was followed by significant leadership changes at key financial institutions. On Jan. 30, the head of Indonesia's financial regulator, several senior officials overseeing capital markets and the chief executive of the stock exchange all resigned. The sudden departures have fueled fears that less independent individuals will fill these leadership positions, potentially opening these key market institutions to greater influence by the president, even as authorities sought to reassure investors that day-to-day market operations would continue without disruption. Since the selloff, markets have stabilized but not recovered.","overview":"","youtube_video_url":"","created":"1770401479","created_formatted":"Feb 6, 2026 | 18:11 GMT","changed":"1770401479","changed_formatted":"Feb 6, 2026 | 18:11 GMT","path_alias":"article/lessons-learned-indonesias-market-rout","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"199","vid":"5","v_name":"countries","name":"Indonesia","code":"ID","path_alias":"/region/asia-pacific/indonesia"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"199","vid":"5","name":"Indonesia"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351926","type":"article","ntype":"worldview","title":"Elections and Referendum Unlikely to End Thailand's Cycle of Constrained Governance","promo_image":{"uri":"public://GettyImages-2258988687.jpg","alt":"People walk past campaign posters in Bangkok on Feb. 2, 2026, ahead of Thailand's Feb. 8 general election.","title":"People walk past campaign posters in Bangkok on Feb. 2, 2026, ahead of Thailand's Feb. 8 general election.","caption":"People walk past campaign posters in Bangkok on Feb. 2, 2026, ahead of Thailand's Feb. 8 general election.","credit":"(Lillian SUWANRUMPHA / AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2258988687.jpg?itok=2QLQPCvP","small":"16x9_small/public/GettyImages-2258988687.jpg?itok=HicGBYVA","medium":"16x9_medium/public/GettyImages-2258988687.jpg?itok=Jp_z8-hc","large":"16x9_large/public/GettyImages-2258988687.jpg?itok=x8tak_UZ","full":"16x9_full/public/GettyImages-2258988687.jpg?itok=Ju0ZxwDn"},"square":{"tiny":"square_tiny/public/GettyImages-2258988687.jpg?itok=OmchwBDH","small":"square_small/public/GettyImages-2258988687.jpg?itok=h-0K_Pq0","medium":"square_medium/public/GettyImages-2258988687.jpg?itok=T24RqxH4","large":"square_large/public/GettyImages-2258988687.jpg?itok=ymI8CG3r","full":"square_full/public/GettyImages-2258988687.jpg?itok=_z2YBesY"},"article":{"tiny":"article_tiny/public/GettyImages-2258988687.jpg?itok=MHYpdB79","small":"article_small/public/GettyImages-2258988687.jpg?itok=IfVJZ2wG","medium":"article_medium/public/GettyImages-2258988687.jpg?itok=4lfcRruR","large":"article_large/public/GettyImages-2258988687.jpg?itok=2bnZcsfd","full":"article_full/public/GettyImages-2258988687.jpg?itok=Zedojxoe"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2258988687.jpg?itok=QCJZitgE","small":"2x1_small/public/GettyImages-2258988687.jpg?itok=X1r-ohmS","medium":"2x1_medium/public/GettyImages-2258988687.jpg?itok=CCpz4vRH","large":"2x1_large/public/GettyImages-2258988687.jpg?itok=RcP9azdK","full":"2x1_full/public/GettyImages-2258988687.jpg?itok=NPDkpy9_"}}},"teaser_body":"Thailand's Feb. 8 general election and constitutional referendum are unlikely to deliver a decisive political reset and will instead risk extending a familiar cycle of constrained reform and policy caution amid heightened security and economic pressures.","pov":"","mailout":"Thailand's general election and constitutional referendum are unlikely to deliver a decisive political reset and will instead risk extending a familiar cycle of contested governance, constrained reform and policy caution amid heightened security pressures and economic underperformance. On Feb. 8, Thailand will hold a general election for the 500-seat House of Representatives and a national referendum on whether to initiate the drafting of a new constitution to replace the 2017 charter. Under Thailand's parallel voting system, 400 members of parliament will be elected from constituencies and 100 from party lists. Forming a government will require the support of at least 251 lawmakers to select a prime minister. The election is being contested primarily by three major political blocs: a progressive and reformist camp led by the People's Party, center-right forces aligned with the governing Bhumjaithai Party and the established political network of the center-left Pheu Thai Party, which advocates redistributive economic policies and welfare expansion. Key campaign issues include economic policy, governance and constitutional reforms, and national security issues following the large-scale cross-border clashes with Cambodia in 2025 and the subsequent failed ceasefires.","overview":"","youtube_video_url":"","created":"1770323285","created_formatted":"Feb 5, 2026 | 20:28 GMT","changed":"1770323285","changed_formatted":"Feb 5, 2026 | 20:28 GMT","path_alias":"article/elections-and-referendum-unlikely-end-thailands-cycle-constrained-governance","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"217","vid":"5","v_name":"countries","name":"Thailand","code":"TH","path_alias":"/region/asia-pacific/thailand"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"217","vid":"5","name":"Thailand"}],"wv_topics":[{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0}],"isLoadingData":false,"type":"","exclude_global_perspectives":0,"exclude_snapshots":0,"exclude_interactives":0},{"template_id":"template13","title":"Assessments","subqueue_id":"","filter":{"type":["article","sectioned_content"],"taxonomy":{"article_type":{"502":"502"},"assessments_type":[],"media_type":[],"global_perspectives_type":[],"column_type":[],"countries":[],"wv_themes":[],"wv_topics":[],"wv_series":[],"wv_event":[],"sectioned_content_type":[],"foreca