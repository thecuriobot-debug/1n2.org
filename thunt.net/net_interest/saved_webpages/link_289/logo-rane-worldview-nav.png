},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2257550121.jpg?itok=hJTsNBi2","small":"2x1_small/public/GettyImages-2257550121.jpg?itok=Nu6753sU","medium":"2x1_medium/public/GettyImages-2257550121.jpg?itok=wLhpwphz","large":"2x1_large/public/GettyImages-2257550121.jpg?itok=_bgCwCty","full":"2x1_full/public/GettyImages-2257550121.jpg?itok=wsgCNld4"}}},"teaser_body":"A look at what the coming week will bring -- and a list of recommended RANE articles from the week that was.","pov":"","mailout":"A look at what the coming week will bring -- and a list of recommended RANE articles from the week that was.","overview":"","youtube_video_url":"","created":"1771077600","created_formatted":"Feb 14, 2026 | 14:00 GMT","changed":"1771077627","changed_formatted":"Feb 14, 2026 | 14:00 GMT","path_alias":"article/weekly-rundown-board-peace-convenes-russia-ukraine-us-talks-geneva","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"59","vid":"5","v_name":"countries","name":"United States","code":"US","path_alias":"/region/americas/united-states"},{"tid":"127","vid":"5","v_name":"countries","name":"Israel","code":"IL","path_alias":"/region/middle-east-and-north-africa/israel"},{"tid":"133","vid":"5","v_name":"countries","name":"Palestinian Territories","code":"PS","path_alias":"/region/middle-east-and-north-africa/palestinian-territories"},{"tid":"199","vid":"5","v_name":"countries","name":"Indonesia","code":"ID","path_alias":"/region/asia-pacific/indonesia"},{"tid":"221","vid":"5","v_name":"countries","name":"Vietnam","code":"VN","path_alias":"/region/asia-pacific/vietnam"},{"tid":"95","vid":"5","v_name":"countries","name":"Slovakia","code":"SK","path_alias":"/region/europe/slovakia"},{"tid":"77","vid":"5","v_name":"countries","name":"Hungary","code":"HU","path_ali