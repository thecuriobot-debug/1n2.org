":"Slovakia"},{"tid":"77","vid":"5","name":"Hungary"},{"tid":"113","vid":"5","name":"Ukraine"},{"tid":"110","vid":"5","name":"Russia"},{"tid":"118","vid":"5","name":"India"}],"wv_topics":[{"tid":"1848","vid":"33","name":"Israel-Hamas Conflict"},{"tid":"529","vid":"33","name":"Military \u0026 Security"},{"tid":"530","vid":"33","name":"Politics"},{"tid":"1840","vid":"33","name":"Russia-Ukraine Conflict"}],"is_bookmarked":0},{"nid":"290404","type":"article","ntype":"worldview","title":"Geopolitical Calendar","promo_image":{"uri":"public://Geopolitical Calendar Display 02212025 (1).png","alt":"","title":"","caption":"","credit":"","sizes":{"16x9":{"tiny":"16x9_tiny/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=T9P3aalD","small":"16x9_small/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=5LXK3mLR","medium":"16x9_medium/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=-Kapc68c","large":"16x9_large/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=Mjo-ZT4S","full":"16x9_full/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=ohIFDc-Q"},"square":{"tiny":"square_tiny/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=G5oZsqCF","small":"square_small/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=hsp0opFR","medium":"square_medium/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=lnqDbWT6","large":"square_large/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=voxtoV-v","full":"square_full/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=wfqx8zOx"},"article":{"tiny":"article_tiny/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=GMIRiQ2c","small":"article_small/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=7sDSOw7o","medium":"article_medium/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=XvKVYFUS","large":"article_large/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=h_kiwHxw","full":"article_full/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=eaMGMb4J"},"2x1":{"tiny":"2x1_tiny/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=mEb6tgej","small":"2x1_small/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=WIvx21Qt","medium":"2x1_medium/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=5Rw5hFvn","large":"2x1_large/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=3EaGWqB5","full":"2x1_full/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=T_k0z6re"}}},"teaser_body":"Stay informed about the significant meetings and events RANE analysts are tracking.","pov":"","mailout":"Stay informed about the significant meetings and events RANE analysts are tracking.","overview":"","youtube_video_url":"","created":"1771014134","created_formatted":"Feb 13, 2026 | 20:22 GMT","changed":"1771014134","changed_formatted":"Feb 13, 2026 | 20:22 GMT","path_alias":"article/geopolitical-calendar","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[],"author":[],"pdf":"","status":1,"premium":1,"is_bookmarked":0},{"nid":"351979","type":"article","ntype":"worldview","title":"In the U.K., Starmer's Leadership Struggles Reach a Tipping Point","promo_image":{"uri":"public://GettyImages-2259578301.jpg","alt":"U.K. Prime Minister Keir Starmer leaves Downing Street on Feb. 2, 2026, in London. ","title":"U.K. Prime Minister Keir Starmer leaves Downing Street on Feb. 2, 2026, in London. ","caption":"U.K. Prime Minister Keir Starmer leaves Downing Street on Feb. 2, 2026, in London.","credit":"(Alishia Abodunde/Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259578301.jpg?itok=S3NZEFfF","small":"16x9_small/public/GettyImages-2259578301.jpg?itok=ZkDhmsZJ","medium":"16x9_medium/public/GettyImages-2259578301.jpg?itok=hqXPZ48L","large":"16x9_large/public/GettyImages-2259578301.jpg?itok=pWoKEHD8","full":"16x9_full/public/GettyImages-2259578301.jpg?itok=nyhphrUX"},"square":{"tiny":"square_tiny/public/GettyImages-2259578301.jpg?itok=aURTbgcL","small":"square_small/public/GettyImages-2259578301.jpg?itok=l_J1KnaB","medium":"square_medium/public/GettyImages-2259578301.jpg?itok=c_aptKxN","large":"square_large/public/GettyImages-2259578301.jpg?itok=Hfs-G8XF","full":"square_full/public/GettyImages-2259578301.jpg?itok=sf_KHi9E"},"article":{"tiny":"article_tiny/public/GettyImages-2259578301.jpg?itok=IEP_4tmN","small":"article_small/public/GettyImages-2259578301.jpg?itok=7IsR6WKq","medium":"article_medium/public/GettyImages-2259578301.jpg?itok=I75hhyQU","large":"article_large/public/GettyImages-2259578301.jpg?itok=d_VjyVeY","full":"article_full/public/GettyImages-2259578301.jpg?itok=CurFH1A4"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259578301.jpg?itok=FmRst5W9","small":"2x1_small/public/GettyImages-2259578301.jpg?itok=EtkeCFDP","medium":"2x1_medium/public/GettyImages-2259578301.jpg?itok=6iepaXAP","large":"2x1_large/public/GettyImages-2259578301.jpg?itok=sMrk64YZ","full":"2x1_full/public/GettyImages-2259578301.jpg?itok=tBn3s-Ci"}}},"teaser_body":"While the crisis could see Labour elect a new leader in the coming months, broad party consensus and fiscal constraints make sharp policy shifts unlikely, limiting the risk of sustained market volatility.","pov":"","mailout":"A deepening internal crisis within Labour is weakening Prime Minister Keir Starmer's authority and raising the likelihood of a leadership challenge, but structural constraints and broad party consensus make sharp policy shifts or a break with the United Kingdom's current fiscal trajectory unlikely, limiting the risk to only limited, short-term market volatility. Starmer's leadership came under acute pressure after renewed controversy over his appointment of Peter Mandelson as ambassador to the United States triggered senior resignations in Downing Street and open calls for him to step aside. Chief of staff Morgan McSweeney resigned on Feb. 8, taking responsibility for advising Starmer on the appointment despite Mandelson's past association with convicted sex offender Jeffrey Epstein. Tim Allan, Starmer's director of communications, followed suit shortly thereafter. Officials cited by British media said cabinet ministers were also preparing to privately urge Starmer to resign or threaten their own departures. On Feb. 9, Scottish Labour leader Anas Sarwar publicly called for Starmer's resignation, becoming the most senior Labour figure to do so. At least for now, however, Starmer maintains the public support of senior government members, including those U.K. media have identified as potential contenders for Labour Party leadership, such as Former Deputy Prime Minister Angela Rayner, Health Secretary Wes Streeting, Home Secretary Shabana Mahmood and Energy Secretary Ed Miliband.","overview":"","youtube_video_url":"","created":"1770752187","created_formatted":"Feb 10, 2026 | 19:36 GMT","changed":"1770752306","changed_formatted":"Feb 10, 2026 | 19:38 GMT","path_alias":"article/uk-starmers-leadership-struggles-reach-tipping-point","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"102","vid":"5","v_name":"countries","name":"United Kingdom","code":"GB","path_alias":"/region/europe/united-kingdom"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"102","vid":"5","name":"United Kingdom"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351972","type":"article","ntype":"worldview","title":"Economic Concessions to U.S. Offer Path for Regime Survival in Cuba","promo_image":{"uri":"public://GettyImages-2260228972.jpg","alt":"American Airlines planes sit on the tarmac at Jose Marti International Airport in Havana on Feb. 9, 2026. ","title":"American Airlines planes sit on the tarmac at Jose Marti International Airport in Havana on Feb. 9, 2026. ","caption":"American Airlines planes sit on the tarmac at Jose Marti International Airport in Havana on Feb. 9, 2026. ","credit":"(YAMIL LAGE/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2260228972.jpg?itok=-jmoWiDX","small":"16x9_small/public/GettyImages-2260228972.jpg?itok=5353kHUl","medium":"16x9_medium/public/GettyImages-2260228972.jpg?itok=2gja2f6S","large":"16x9_large/public/GettyImages-2260228972.jpg?itok=Li0IgqY-","full":"16x9_full/public/GettyImages-2260228972.jpg?itok=so9AwDdc"},"square":{"tiny":"square_tiny/public/GettyImages-2260228972.jpg?itok=MoWCH8yR","small":"square_small/public/GettyImages-2260228972.jpg?itok=oOeQQqaP","medium":"square_medium/public/GettyImages-2260228972.jpg?itok=SWdj_kqQ","large":"square_large/public/GettyImages-2260228972.jpg?itok=_Iuw4E5g","full":"square_full/public/GettyImages-2260228972.jpg?itok=5_sd8lXR"},"article":{"tiny":"article_tiny/public/GettyImages-2260228972.jpg?itok=aOgmjH_l","small":"article_small/public/GettyImages-2260228972.jpg?itok=ykVI-RHl","medium":"article_medium/public/GettyImages-2260228972.jpg?itok=aIgO_PTk","large":"article_large/public/GettyImages-2260228972.jpg?itok=uhZIpEWl","full":"article_full/public/GettyImages-2260228972.jpg?itok=1Oqfi0n-"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2260228972.jpg?itok=G_aE7MGI","small":"2x1_small/public/GettyImages-2260228972.jpg?itok=lHSgB0gs","medium":"2x1_medium/public/GettyImages-2260228972.jpg?itok=k0elTWVc","large":"2x1_large/public/GettyImages-2260228972.jpg?itok=5fHCHHd8","full":"2x1_full/public/GettyImages-2260228972.jpg?itok=pLyr6qVF"}}},"teaser_body":"Facing imminent economic collapse and the loss of key allies, the Cuban government will likely yield to U.S. demands for market liberalization to avoid a total breakdown of state authority while attempting to preserve political control.","pov":"","mailout":"Facing imminent collapse and mounting U.S. pressure, the Cuban government will likely make concessions to Washington to gradually open its economy without requiring structural political changes, which the United States will likely support to avoid a state collapse and reaffirm its geopolitical dominance in the Western Hemisphere.","overview":"","youtube_video_url":"","created":"1770749346","created_formatted":"Feb 10, 2026 | 18:49 GMT","changed":"1770826465","changed_formatted":"Feb 11, 2026 | 16:14 GMT","path_alias":"article/economic-concessions-us-offer-path-regime-survival-cuba","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"39","vid":"5","v_name":"countries","name":"Cuba","code":"CU","path_alias":"/region/americas/cuba"},{"tid":"49","vid":"5","v_name":"countries","name":"Mexico","code":"MX","path_alias":"/region/americas/mexico"},{"tid":"59","vid":"5","v_name":"countries","name":"United States","code":"US","path_alias":"/region/americas/united-states"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"526","vid":"33","v_name":"wv_topics","name":"Energy","path_alias":"/topic/energy"},{"tid":"529","vid":"33","v_name":"wv_topics","name":"Military \u0026 Security","path_alias":"/topic/military-security"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"39","vid":"5","name":"Cuba"},{"tid":"49","vid":"5","name":"Mexico"},{"tid":"59","vid":"5","name":"United States"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"526","vid":"33","name":"Energy"},{"tid":"529","vid":"33","name":"Military \u0026 Security"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351968","type":"article","ntype":"worldview","title":"Election Landslide Stabilizes Japanese Politics, Cements Defense Modernization","promo_image":{"uri":"public://GettyImages-2259987841.jpg","alt":"Japanese Prime Minister and President of the Liberal Democratic Party (LDP) Sanae Takaichi reacts as she speaks with media on the day of lower house elections at the LDP headquarters in Tokyo on Feb. 8, 2026. ","title":"Japanese Prime Minister and President of the Liberal Democratic Party (LDP) Sanae Takaichi reacts as she speaks with media on the day of lower house elections at the LDP headquarters in Tokyo on Feb. 8, 2026. ","caption":"Japanese Prime Minister and President of the Liberal Democratic Party (LDP) Sanae Takaichi reacts as she speaks with media on the day of lower house elections at the LDP headquarters in Tokyo on Feb. 8, 2026.","credit":"(Kim Kyung-Hoon / POOL / AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259987841.jpg?itok=y-L9LnM1","small":"16x9_small/public/GettyImages-2259987841.jpg?itok=mAo7WYNu","medium":"16x9_medium/public/GettyImages-2259987841.jpg?itok=tRRQojaz","large":"16x9_large/public/GettyImages-2259987841.jpg?itok=opyMYmJ2","full":"16x9_full/public/GettyImages-2259987841.jpg?itok=I7p-D2Qe"},"square":{"tiny":"square_tiny/public/GettyImages-2259987841.jpg?itok=I1aZSLR9","small":"square_small/public/GettyImages-2259987841.jpg?itok=A4F5ut0i","medium":"square_medium/public/GettyImages-2259987841.jpg?itok=07fwFraz","large":"square_large/public/GettyImages-2259987841.jpg?itok=wqAXeEm1","full":"square_full/public/GettyImages-2259987841.jpg?itok=bicXIZC1"},"article":{"tiny":"article_tiny/public/GettyImages-2259987841.jpg?itok=rv6UY8vu","small":"article_small/public/GettyImages-2259987841.jpg?itok=c-KjrKL6","medium":"article_medium/public/GettyImages-2259987841.jpg?itok=dlPftPmK","large":"article_large/public/GettyImages-2259987841.jpg?itok=2WFgd2LC","full":"article_full/public/GettyImages-2259987841.jpg?itok=2BHBkOKC"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259987841.jpg?itok=4hfCDB6u","small":"2x1_small/public/GettyImages-2259987841.jpg?itok=f3Vz0Kyf","medium":"2x1_medium/public/GettyImages-2259987841.jpg?itok=F3fy19tC","large":"2x1_large/public/GettyImages-2259987841.jpg?itok=u8hLEU0B","full":"2x1_full/public/GettyImages-2259987841.jpg?itok=RZySD0-g"}}},"teaser_body":"The LDP's decisive lower house victory will enable Prime Minister Takaichi to boost social and defense spending and strengthen ties with the U.S., though at the expense of Japan’s relations with China and South Korea.","pov":"","mailout":"A major electoral victory by Japan's ruling party will enable conservative Prime Minister Sanae Takaichi to expand social and defense spending, ease lingering concerns about political instability and bolster ties with the United States, though at the expense of those with China and potentially South Korea. Takaichi's ruling Liberal Democratic Party (LDP) won 316 out of 465 seats in the Feb. 8 snap elections for the lower house of the Diet, giving it a rare supermajority and the largest seat share in its party history. When combined with its coalition partner, the Japan Innovation Party, the LDP-led government now has 352 seats. Opposition parties, on the other hand, heavily underperformed. The main opposition Centrist Reform Alliance (CRA) -- formed in recent weeks by a merger of the center-left Constitutional Democratic Party and former LDP coalition partner, the center-left Komeito -- saw its seat count drop from 167 to just 49. Other opposition parties across the political spectrum also generally underperformed, with the exception of the right-wing nativist party Sanseito, which rose from two to 15 seats. The Diet will convene a special session on Feb. 18 to vote on the next prime minister, which Takaichi is guaranteed to win. The session will also hand control of the powerful lower house standing committees to the LDP and belatedly commence work on the 2026 budget, which is due by March 31.","overview":"","youtube_video_url":"","created":"1770676588","created_formatted":"Feb 9, 2026 | 22:36 GMT","changed":"1770676588","changed_formatted":"Feb 9, 2026 | 22:36 GMT","path_alias":"article/election-landslide-stabilizes-japanese-politics-cements-defense-modernization","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"200","vid":"5","v_name":"countries","name":"Japan","code":"JP","path_alias":"/region/asia-pacific/japan"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"200","vid":"5","name":"Japan"}],"wv_topics":[{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351958","type":"article","ntype":"worldview","title":"In Tunisia, UGTT Infighting Risks Playing Into President Saied's Hands","promo_image":{"uri":"public://GettyImages-2230479411.jpg","alt":"Supporters of Tunisia's General Labour Union (UGTT) wave the national flag during a rally in Tunis on Aug. 21, 2025.","title":"Supporters of Tunisia's General Labour Union (UGTT) wave the national flag during a rally in Tunis on Aug. 21, 2025.","caption":"Supporters of Tunisia's General Labour Union (UGTT) wave the national flag during a rally in Tunis on Aug. 21, 2025.","credit":"(FETHI BELAID/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2230479411.jpg?itok=7Q6OnFaI","small":"16x9_small/public/GettyImages-2230479411.jpg?itok=zZ5mgjsU","medium":"16x9_medium/public/GettyImages-2230479411.jpg?itok=sIX6jTBC","large":"16x9_large/public/GettyImages-2230479411.jpg?itok=ZrYuLuL7","full":"16x9_full/public/GettyImages-2230479411.jpg?itok=ikeg2Xw6"},"square":{"tiny":"square_tiny/public/GettyImages-2230479411.jpg?itok=_YjxNxQ1","small":"square_small/public/GettyImages-2230479411.jpg?itok=9VmsttyC","medium":"square_medium/public/GettyImages-2230479411.jpg?itok=SbU5LHSe","large":"square_large/public/GettyImages-2230479411.jpg?itok=nMqRLtK9","full":"square_full/public/GettyImages-2230479411.jpg?itok=kWqdEfGc"},"article":{"tiny":"article_tiny/public/GettyImages-2230479411.jpg?itok=Rbuvv2V2","small":"article_small/public/GettyImages-2230479411.jpg?itok=uJQc_3XU","medium":"article_medium/public/GettyImages-2230479411.jpg?itok=pIokp_9r","large":"article_large/public/GettyImages-2230479411.jpg?itok=aIORQCU_","full":"article_full/public/GettyImages-2230479411.jpg?itok=uGxCiXvq"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2230479411.jpg?itok=CjKjlwEv","small":"2x1_small/public/GettyImages-2230479411.jpg?itok=kwVLxLf5","medium":"2x1_medium/public/GettyImages-2230479411.jpg?itok=W5YOeM2f","large":"2x1_large/public/GettyImages-2230479411.jpg?itok=9lViFEbT","full":"2x1_full/public/GettyImages-2230479411.jpg?itok=NH-EsFKW"}}},"teaser_body":"If the UGTT fails to resolve internal disputes and stage an effective national strike, President Saied will likely launch an expanded crackdown that further weakens the powerful labor union and, consequently, its private-sector bargaining power.","pov":"","mailout":"In Tunisia, officials from the country's influential labor union confederation will likely try to mend internal disputes to increase the effectiveness of any rescheduled national strike, but failure to do so would likely embolden Tunisian President Kais Saied to further erode the union's strength and, in turn, private-sector bargaining power. Nearly three weeks have passed since the Tunisian General Labor Union, or UGTT, had originally intended to conduct a nationwide general strike on Jan. 21. On Jan. 23, the union's deputy secretary-general suggested that a decision regarding the future of the strike would be determined at the union's congress, tentatively scheduled for March 25-27. Union leadership originally called for the strike in December 2025 to protest the Tunisian government's crackdown on the opposition, protect the union's right to collective bargaining after the central government sidelined the union from wage and pension increase negotiations, and call for dialogue between government and union leaders. The decision to postpone the strike came amid internal disputes and uncertainty over union leadership following several officials' resignations. Most notably, Nourreddine Taboubi, the secretary-general, submitted his resignation on Dec. 23 but later withdrew it on Jan. 13, in what some critics alleged was a calculated move to pressure union leaders ahead of the legal deadline to call off a strike. Taboubi's resignation elevated concerns among union officials that the change in leadership -- particularly ahead of a planned nationwide strike -- risked deeper fragmentation and could fuel internal divisions.","overview":"","youtube_video_url":"","created":"1770665104","created_formatted":"Feb 9, 2026 | 19:25 GMT","changed":"1770665104","changed_formatted":"Feb 9, 2026 | 19:25 GMT","path_alias":"article/tunisia-ugtt-infighting-risks-playing-president-saieds-hands","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"188","vid":"5","v_name":"countries","name":"Tunisia","code":"TN","path_alias":"/region/middle-east-and-north-africa/tunisia"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"188","vid":"5","name":"Tunisia"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351951","type":"article","ntype":"worldview","title":"What To Expect From Bangladesh's Upcoming Elections","promo_image":{"uri":"public://Decision_Advantage_Draft_Logo_4bk7hl.png","alt":"The Decision Advantage RANE Podcast","title":"","caption":"","credit":"(RANE)","sizes":{"16x9":{"tiny":"16x9_tiny/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=GKkyDOwk","small":"16x9_small/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=zgG5wqsi","medium":"16x9_medium/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=BObFpCwf","large":"16x9_large/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=heGglv-9","full":"16x9_full/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=uZ_PmNG-"},"square":{"tiny":"square_tiny/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=3nDFEoal","small":"square_small/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=RzYNC4f6","medium":"square_medium/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=n4V6I0Bn","large":"square_large/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=Cchdv_Au","full":"square_full/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=YKu8adkQ"},"article":{"tiny":"article_tiny/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=V5_xxq2A","small":"article_small/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=lRj5xni6","medium":"article_medium/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=K4-l1F41","large":"article_large/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=OZ8-JBu6","full":"article_full/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=PlLQXvPf"},"2x1":{"tiny":"2x1_tiny/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=Dmtky7Eq","small":"2x1_small/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=sZzFIQSD","medium":"2x1_medium/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=6fjTujvH","large":"2x1_large/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=UOBMheMq","full":"2x1_full/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=tPPcHTwx"}}},"teaser_body":"What major challenges will the incoming government face?","pov":"","mailout":"In this episode of The Decision Advantage, RANE South Asia Analyst Misha Iqbal discusses the major players and pressures shaping the outlook for Bangladesh's first election following the pro-democracy uprising that ousted Sheikh Hasina in 2024.","overview":"","youtube_video_url":"","created":"1770663481","created_formatted":"Feb 9, 2026 | 18:58 GMT","changed":"1770740277","changed_formatted":"Feb 10, 2026 | 16:17 GMT","path_alias":"article/what-expect-bangladeshs-upcoming-elections","article_type":{"tid":"606","vid":"30","name":"Media"},"assessments_type":[],"column_type":[],"media_type":{"tid":"605","vid":"38","name":"Podcasts"},"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"116","vid":"5","v_name":"countries","name":"Bangladesh","code":"BD","path_alias":"/region/south-asia/bangladesh"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":0,"countries":[{"tid":"116","vid":"5","name":"Bangladesh"}],"wv_topics":[{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351939","type":"article","ntype":"worldview","title":"The Weekly Rundown: Japan Holds Snap Elections, U.S. Weighs Options After Iran Talks","promo_image":{"uri":"public://GettyImages-2259572154.jpg","alt":"Campaign posters Feb. 6 of candidates running in the upcoming Japanese House of Representatives election, in Inagi, Tokyo prefecture.","title":"Campaign posters Feb. 6 of candidates running in the upcoming Japanese House of Representatives election, in Inagi, Tokyo prefecture.","caption":"Campaign posters Feb. 6 of candidates running in the upcoming Japanese House of Representatives election, in Inagi, Tokyo prefecture.","credit":"(Yuichi YAMAZAKI/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259572154.jpg?itok=ZXSZ5wo2","small":"16x9_small/public/GettyImages-2259572154.jpg?itok=F0Ru79YU","medium":"16x9_medium/public/GettyImages-2259572154.jpg?itok=D6U8ewu9","large":"16x9_large/public/GettyImages-2259572154.jpg?itok=ZvRkuh42","full":"16x9_full/public/GettyImages-2259572154.jpg?itok=DY8ST9TU"},"square":{"tiny":"square_tiny/public/GettyImages-2259572154.jpg?itok=WeZzGMyB","small":"square_small/public/GettyImages-2259572154.jpg?itok=wFa_swX-","medium":"square_medium/public/GettyImages-2259572154.jpg?itok=u3ZGAEXS","large":"square_large/public/GettyImages-2259572154.jpg?itok=jAKXjIfT","full":"square_full/public/GettyImages-2259572154.jpg?itok=M__qwY5V"},"article":{"tiny":"article_tiny/public/GettyImages-2259572154.jpg?itok=VgytrZAT","small":"article_small/public/GettyImages-2259572154.jpg?itok=sLoXacxF","medium":"article_medium/public/GettyImages-2259572154.jpg?itok=m7SO6im5","large":"article_large/public/GettyImages-2259572154.jpg?itok=Q1MPaGC_","full":"article_full/public/GettyImages-2259572154.jpg?itok=Bk-gjJFL"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259572154.jpg?itok=Jq_kEV9E","small":"2x1_small/public/GettyImages-2259572154.jpg?itok=DFdpAqb0","medium":"2x1_medium/public/GettyImages-2259572154.jpg?itok=thklhx_T","large":"2x1_large/public/GettyImages-2259572154.jpg?itok=i9QLrx93","full":"2x1_full/public/GettyImages-2259572154.jpg?itok=IJSI6Yc5"}}},"teaser_body":"A look at what the coming week will bring -- and a list of recommended RANE articles from the week that was.","pov":"","mailout":"A look at what the coming week will bring -- and a list of recommended RANE articles from the week that was.","overview":"","youtube_video_url":"","created":"1770472800","created_formatted":"Feb 7, 2026 | 14:00 GMT","changed":"1770472827","changed_formatted":"Feb 7, 2026 | 14:00 GMT","path_alias":"article/weekly-rundown-japan-holds-snap-elections-us-weighs-options-after-iran-talks","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"59","vid":"5","v_name":"countries","name":"United States","code":"US","path_alias":"/region/americas/united-states"},{"tid":"125","vid":"5","v_name":"countries","name":"Iran","code":"IR","path_alias":"/region/middle-east-and-north-africa/iran"},{"tid":"200","vid":"5","v_name":"countries","name":"Japan","code":"JP","path_alias":"/region/asia-pacific/japan"},{"tid":"217","vid":"5","v_name":"countries","name":"Thailand","code":"TH","path_alias":"/region/asia-pacific/thailand"},{"tid":"116","vid":"5","v_name":"countries","name":"Bangladesh","code":"BD","path_alias":"/region/south-asia/bangladesh"},{"tid":"529","vid":"33","v_name":"wv_topics","name":"Military \u0026 Security","path_alias":"/topic/military-security"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"59","vid":"5","name":"United States"},{"tid":"125","vid":"5","name":"Iran"},{"tid":"200","vid":"5","name":"Japan"},{"tid":"217","vid":"5","name":"Thailand"},{"tid":"116","vid":"5","name":"Bangladesh"}],"wv_topics":[{"tid":"529","vid":"33","name":"Military \u0026 Security"},{"tid":"530","vid":"33","name":"Politics"},{"tid":"1660","vid":"33","name":"U.S.-Iran Relations"}],"is_bookmarked":0},{"nid":"351937","type":"article","ntype":"worldview","title":"The Limits of Russia-Ukraine-U.S. Talks","promo_image":{"uri":"public://GettyImages-2259311376.jpg","alt":"Emirati flags on Feb. 4 in Abu Dhabi, UAE.","title":"Emirati flags on Feb. 4 in Abu Dhabi, UAE. On Feb. 4-5, delegations from Russia, Ukraine and the United States held a second round of trilateral talks in the United Arab Emirates.","caption":"Emirati flags on Feb. 4 in Abu Dhabi, UAE.","credit":"(CACACE/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259311376.jpg?itok=O0990CCQ","small":"16x9_small/public/GettyImages-2259311376.jpg?itok=9AMR0gC5","medium":"16x9_medium/public/GettyImages-2259311376.jpg?itok=yhu7l95X","large":"16x9_large/public/GettyImages-2259311376.jpg?itok=ZnsU-lcL","full":"16x9_full/public/GettyImages-2259311376.jpg?itok=ueRSUL_5"},"square":{"tiny":"square_tiny/public/GettyImages-2259311376.jpg?itok=7xKZLKtf","small":"square_small/public/GettyImages-2259311376.jpg?itok=3Bs9Ppi5","medium":"square_medium/public/GettyImages-2259311376.jpg?itok=8Xs9NrbC","large":"square_large/public/GettyImages-2259311376.jpg?itok=OjskrbN0","full":"square_full/public/GettyImages-2259311376.jpg?itok=ToLUs0Kg"},"article":{"tiny":"article_tiny/public/GettyImages-2259311376.jpg?itok=XnWu9E1h","small":"article_small/public/GettyImages-2259311376.jpg?itok=QqNAGeHk","medium":"article_medium/public/GettyImages-2259311376.jpg?itok=sCEeJN7D","large":"article_large/public/GettyImages-2259311376.jpg?itok=m5hGFbhZ","full":"article_full/public/GettyImages-2259311376.jpg?itok=bNuY0NZZ"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259311376.jpg?itok=PoBSNoVW","small":"2x1_small/public/GettyImages-2259311376.jpg?itok=GmlJYJrA","medium":"2x1_medium/public/GettyImages-2259311376.jpg?itok=cTl2fS1W","large":"2x1_large/public/GettyImages-2259311376.jpg?itok=0vo3Ikn-","full":"2x1_full/public/GettyImages-2259311376.jpg?itok=4Xe_rnz9"}}},"teaser_body":"The talks are unlikely to produce a near-term settlement, as Russia will continue to press its territorial demands while using diplomacy to manage sanctions pressure and build leverage ahead of a spring-summer offensive.","pov":"","mailout":"U.S.-brokered talks between Russia and Ukraine will likely continue, and to deliver limited confidence-building steps. But they are unlikely to produce a near-term settlement, as Russia will continue to press its territorial demands while using diplomacy to manage sanctions pressure and build leverage ahead of a spring-summer offensive.","overview":"","youtube_video_url":"","created":"1770405545","created_formatted":"Feb 6, 2026 | 19:19 GMT","changed":"1770406072","changed_formatted":"Feb 6, 2026 | 19:27 GMT","path_alias":"article/limits-russia-ukraine-us-talks","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"59","vid":"5","v_name":"countries","name":"United States","code":"US","path_alias":"/region/americas/united-states"},{"tid":"138","vid":"5","v_name":"countries","name":"United Arab Emirates","code":"AE","path_alias":"/region/middle-east-and-north-africa/united-arab-emirates"},{"tid":"113","vid":"5","v_name":"countries","name":"Ukraine","code":"UA","path_alias":"/region/eurasia/ukraine"},{"tid":"110","vid":"5","v_name":"countries","name":"Russia","code":"RU","path_alias":"/region/eurasia/russia"},{"tid":"529","vid":"33","v_name":"wv_topics","name":"Military \u0026 Security","path_alias":"/topic/military-security"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"},{"tid":"1840","vid":"33","v_name":"wv_topics","name":"Russia-Ukraine Conflict","path_alias":"/topic/russia-ukraine-conflict"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"59","vid":"5","name":"United States"},{"tid":"138","vid":"5","name":"United Arab Emirates"},{"tid":"113","vid":"5","name":"Ukraine"},{"tid":"110","vid":"5","name":"Russia"}],"wv_topics":[{"tid":"529","vid":"33","name":"Military \u0026 Security"},{"tid":"530","vid":"33","name":"Politics"},{"tid":"1840","vid":"33","name":"Russia-Ukraine Conflict"}],"is_bookmarked":0},{"nid":"351936","type":"article","ntype":"worldview","title":"Lessons Learned From Indonesia's Market Rout","promo_image":{"uri":"public://GettyImages-2258212948 (1).jpg","alt":"Visitors take pictures in front of an electronic board displaying falling stock prices at the Indonesia Stock Exchange in Jakarta on Jan. 29, 2026.","title":"Visitors take pictures in front of an electronic board displaying falling stock prices at the Indonesia Stock Exchange in Jakarta on Jan. 29, 2026.","caption":"Visitors take pictures in front of an electronic board displaying falling stock prices at the Indonesia Stock Exchange in Jakarta on Jan. 29, 2026.","credit":"(YASUYOSHI CHIBA / AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=paonbKCG","small":"16x9_small/public/GettyImages-2258212948%20%281%29.jpg?itok=HZXNR7N2","medium":"16x9_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=12Gl42M7","large":"16x9_large/public/GettyImages-2258212948%20%281%29.jpg?itok=MkzNtyoC","full":"16x9_full/public/GettyImages-2258212948%20%281%29.jpg?itok=xhVFtvCw"},"square":{"tiny":"square_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=27dRLCmW","small":"square_small/public/GettyImages-2258212948%20%281%29.jpg?itok=5gTXsTu_","medium":"square_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=734pUUqt","large":"square_large/public/GettyImages-2258212948%20%281%29.jpg?itok=7fw3unKh","full":"square_full/public/GettyImages-2258212948%20%281%29.jpg?itok=r5NP-X6Z"},"article":{"tiny":"article_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=CZ-ArUvP","small":"article_small/public/GettyImages-2258212948%20%281%29.jpg?itok=3Oyyd-Xi","medium":"article_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=qCor6Hs9","large":"article_large/public/GettyImages-2258212948%20%281%29.jpg?itok=qoVCixbi","full":"article_full/public/GettyImages-2258212948%20%281%29.jpg?itok=xXau38a4"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2258212948%20%281%29.jpg?itok=VffYvvQ_","small":"2x1_small/public/GettyImages-2258212948%20%281%29.jpg?itok=8_ee7EGO","medium":"2x1_medium/public/GettyImages-2258212948%20%281%29.jpg?itok=QuFQx3a4","large":"2x1_large/public/GettyImages-2258212948%20%281%29.jpg?itok=3FJ3Mm0f","full":"2x1_full/public/GettyImages-2258212948%20%281%29.jpg?itok=1MoQyNQE"}}},"teaser_body":"The episode exposes structural risks embedded in the president's governance that could threaten investor confidence -- and with it, Indonesia's economic growth and manufacturing competitiveness.","pov":"","mailout":"Indonesia's market rout has exposed deeper structural and governance vulnerabilities that now threaten investor confidence, complicate the government's investment-led growth strategy and raise risks to the country's competitiveness as a regional manufacturing hub. On Jan. 29, Indonesia's equity market sold off sharply after MSCI, a U.S.-based global index provider, raised concerns about the \"investability\" of Indonesian equities. MSCI cited opaque ownership structures, a small proportion of shares available for public trading and insufficient transparency around trading and shareholder data, and warned that Indonesia's equity market could be downgraded from \"emerging market\" to \"frontier market\" status if deficiencies were not addressed ahead of MSCI's scheduled May index review. Following the warning, the benchmark Jakarta Composite Index fell more than 8% over two consecutive trading days, including a steep intraday decline on Jan. 30 that triggered an automatic trading halt under exchange volatility rules. The selloff wiped out an estimated $80 billion in market capitalization before prices stabilized later in the day, following public statements and press briefings by the Ministry of Finance, Bank Indonesia, the Financial Services Authority and the Indonesia Stock Exchange outlining prospective regulatory and market support measures. At the same time, financial stress spilled into currency markets, causing the Indonesian rupiah to weaken by approximately 4%; the currency traded near record lows before stabilizing. The episode escalated further on Feb. 5 when Moody's Ratings cut Indonesia's sovereign credit rating outlook from \"stable\" to \"negative,\" citing lower policy predictability, rising fiscal pressures, weakening foreign reserves and debt risks linked to state-owned enterprises, broadening the episode from an equity market shock into an explicit warning about sovereign policy credibility. The market selloff was followed by significant leadership changes at key financial institutions. On Jan. 30, the head of Indonesia's financial regulator, several senior officials overseeing capital markets and the chief executive of the stock exchange all resigned. The sudden departures have fueled fears that less independent individuals will fill these leadership positions, potentially opening these key market institutions to greater influence by the president, even as authorities sought to reassure investors that day-to-day market operations would continue without disruption. Since the selloff, markets have stabilized but not recovered.","overview":"","youtube_video_url":"","created":"1770401479","created_formatted":"Feb 6, 2026 | 18:11 GMT","changed":"1770401479","changed_formatted":"Feb 6, 2026 | 18:11 GMT","path_alias":"article/lessons-learned-indonesias-market-rout","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"199","vid":"5","v_name":"countries","name":"Indonesia","code":"ID","path_alias":"/region/asia-pacific/indonesia"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"199","vid":"5","name":"Indonesia"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351926","type":"article","ntype":"worldview","title":"Elections and Referendum Unlikely to End Thailand's Cycle of Constrained Governance","promo_image":{"uri":"public://GettyImages-2258988687.jpg","alt":"People walk past campaign posters in Bangkok on Feb. 2, 2026, ahead of Thailand's Feb. 8 general election.","title":"People walk past campaign posters in Bangkok on Feb. 2, 2026, ahead of Thailand's Feb. 8 general election.","caption":"People walk past campaign posters in Bangkok on Feb. 2, 2026, ahead of Thailand's Feb. 8 general election.","credit":"(Lillian SUWANRUMPHA / AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2258988687.jpg?itok=2QLQPCvP","small":"16x9_small/public/GettyImages-2258988687.jpg?itok=HicGBYVA","medium":"16x9_medium/public/GettyImages-2258988687.jpg?itok=Jp_z8-hc","large":"16x9_large/public/GettyImages-2258988687.jpg?itok=x8tak_UZ","full":"16x9_full/public/GettyImages-2258988687.jpg?itok=Ju0ZxwDn"},"square":{"tiny":"square_tiny/public/GettyImages-2258988687.jpg?itok=OmchwBDH","small":"square_small/public/GettyImages-2258988687.jpg?itok=h-0K_Pq0","medium":"square_medium/public/GettyImages-2258988687.jpg?itok=T24RqxH4","large":"square_large/public/GettyImages-2258988687.jpg?itok=ymI8CG3r","full":"square_full/public/GettyImages-2258988687.jpg?itok=_z2YBesY"},"article":{"tiny":"article_tiny/public/GettyImages-2258988687.jpg?itok=MHYpdB79","small":"article_small/public/GettyImages-2258988687.jpg?itok=IfVJZ2wG","medium":"article_medium/public/GettyImages-2258988687.jpg?itok=4lfcRruR","large":"article_large/public/GettyImages-2258988687.jpg?itok=2bnZcsfd","full":"article_full/public/GettyImages-2258988687.jpg?itok=Zedojxoe"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2258988687.jpg?itok=QCJZitgE","small":"2x1_small/public/GettyImages-2258988687.jpg?itok=X1r-ohmS","medium":"2x1_medium/public/GettyImages-2258988687.jpg?itok=CCpz4vRH","large":"2x1_large/public/GettyImages-2258988687.jpg?itok=RcP9azdK","full":"2x1_full/public/GettyImages-2258988687.jpg?itok=NPDkpy9_"}}},"teaser_body":"Thailand's Feb. 8 general election and constitutional referendum are unlikely to deliver a decisive political reset and will instead risk extending a familiar cycle of constrained reform and policy caution amid heightened security and economic pressures.","pov":"","mailout":"Thailand's general election and constitutional referendum are unlikely to deliver a decisive political reset and will instead risk extending a familiar cycle of contested governance, constrained reform and policy caution amid heightened security pressures and economic underperformance. On Feb. 8, Thailand will hold a general election for the 500-seat House of Representatives and a national referendum on whether to initiate the drafting of a new constitution to replace the 2017 charter. Under Thailand's parallel voting system, 400 members of parliament will be elected from constituencies and 100 from party lists. Forming a government will require the support of at least 251 lawmakers to select a prime minister. The election is being contested primarily by three major political blocs: a progressive and reformist camp led by the People's Party, center-right forces aligned with the governing Bhumjaithai Party and the established political network of the center-left Pheu Thai Party, which advocates redistributive economic policies and welfare expansion. Key campaign issues include economic policy, governance and constitutional reforms, and national security issues following the large-scale cross-border clashes with Cambodia in 2025 and the subsequent failed ceasefires.","overview":"","youtube_video_url":"","created":"1770323285","created_formatted":"Feb 5, 2026 | 20:28 GMT","changed":"1770323285","changed_formatted":"Feb 5, 2026 | 20:28 GMT","path_alias":"article/elections-and-referendum-unlikely-end-thailands-cycle-constrained-governance","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"217","vid":"5","v_name":"countries","name":"Thailand","code":"TH","path_alias":"/region/asia-pacific/thailand"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"217","vid":"5","name":"Thailand"}],"wv_topics":[{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0}]},{"title":"Assessments","template_id":"template13","limit":"8","type":"filtered_content_feed","subqueue_id":"","filter":{"type":["article","sectioned_content"],"taxonomy":{"article_type":{"502":"502"},"assessments_type":[],"media_type":[],"global_perspectives_type":[],"column_type":[],"countries":[],"wv_themes":[],"wv_topics":[],"wv_series":[],"wv_event":[],"sectioned_content_type":[],"forecast_type":[]}},"nodes":[{"nid":"352021","type":"article","ntype":"worldview","title":"The Weekly Rundown: The Board of Peace Convenes, Russia-Ukraine-U.S. Talks in Geneva","promo_image":{"uri":"public://GettyImages-2257550121.jpg","alt":"U.S. President Donald Trump (C) holds up his signature on the founding charter of the Board of Peace among other world leaders at the World Economic Forum on Jan. 22 in Davos, Switzerland.","tit