y%2002212025%20%281%29.png?itok=wfqx8zOx"},"article":{"tiny":"article_tiny/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=GMIRiQ2c","small":"article_small/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=7sDSOw7o","medium":"article_medium/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=XvKVYFUS","large":"article_large/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=h_kiwHxw","full":"article_full/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=eaMGMb4J"},"2x1":{"tiny":"2x1_tiny/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=mEb6tgej","small":"2x1_small/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=WIvx21Qt","medium":"2x1_medium/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=5Rw5hFvn","large":"2x1_large/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=3EaGWqB5","full":"2x1_full/public/Geopolitical%20Calendar%20Display%2002212025%20%281%29.png?itok=T_k0z6re"}}},"teaser_body":"Stay informed about the significant meetings and events RANE analysts are tracking.","pov":"","mailout":"Stay informed about the significant meetings and events RANE analysts are tracking.","overview":"","youtube_video_url":"","created":"1771014134","created_formatted":"Feb 13, 2026 | 20:22 GMT","changed":"1771014134","changed_formatted":"Feb 13, 2026 | 20:22 GMT","path_alias":"article/geopolitical-calendar","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[],"author":[],"pdf":"","status":1,"premium":1,"is_bookmarked":0},{"nid":"351979","type":"article","ntype":"worldview","title":"In the U.K., Starmer's Leadership Struggles Reach a Tipping Point","promo_image":{"uri":"public://GettyImages-2259578301.jpg","alt":"U.K. Prime Minister Keir Starmer leaves Downing Street on Feb. 2, 2026, in London. ","title":"U.K. Prime Minister Keir Starmer leaves Downing Street on Feb. 2, 2026, in London. ","caption":"U.K. Prime Minister Keir Starmer leaves Downing Street on Feb. 2, 2026, in London.","credit":"(Alishia Abodunde/Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259578301.jpg?itok=S3NZEFfF","small":"16x9_small/public/GettyImages-2259578301.jpg?itok=ZkDhmsZJ","medium":"16x9_medium/public/GettyImages-2259578301.jpg?itok=hqXPZ48L","large":"16x9_large/public/GettyImages-2259578301.jpg?itok=pWoKEHD8","full":"16x9_full/public/GettyImages-2259578301.jpg?itok=nyhphrUX"},"square":{"tiny":"square_tiny/public/GettyImages-2259578301.jpg?itok=aURTbgcL","small":"square_small/public/GettyImages-2259578301.jpg?itok=l_J1KnaB","medium":"square_medium/public/GettyImages-2259578301.jpg?itok=c_aptKxN","large":"square_large/public/GettyImages-2259578301.jpg?itok=Hfs-G8XF","full":"square_full/public/GettyImages-2259578301.jpg?itok=sf_KHi9E"},"article":{"tiny":"article_tiny/public/GettyImages-2259578301.jpg?itok=IEP_4tmN","small":"article_small/public/GettyImages-2259578301.jpg?itok=7IsR6WKq","medium":"article_medium/public/GettyImages-2259578301.jpg?itok=I75hhyQU","large":"article_large/public/GettyImages-2259578301.jpg?itok=d_VjyVeY","full":"article_full/public/GettyImages-2259578301.jpg?itok=CurFH1A4"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259578301.jpg?itok=FmRst5W9","small":"2x1_small/public/GettyImages-2259578301.jpg?itok=EtkeCFDP","medium":"2x1_medium/public/GettyImages-2259578301.jpg?itok=6iepaXAP","large":"2x1_large/public/GettyImages-2259578301.jpg?itok=sMrk64YZ","full":"2x1_full/public/GettyImages-2259578301.jpg?itok=tBn3s-Ci"}}},"teaser_body":"While the crisis could see Labour elect a new leader in the coming months, broad party consensus and fiscal constraints make sharp policy shifts unlikely, limiting the risk of sustained market volatility.","pov":"","mailout":"A deepening internal crisis within Labour is weakening Prime Minister Keir Starmer's authority and raising the likelihood of a leadership challenge, but structural constraints and broad party consensus make sharp policy shifts or a break with the United Kingdom's current fiscal trajectory unlikely, limiting the risk to only limited, short-term market volatility. Starmer's leadership came under acute pressure after renewed controversy over his appointment of Peter Mandelson as ambassador to the United States triggered senior resignations in Downing Street and open calls for him to step aside. Chief of staff Morgan McSweeney resigned on Feb. 8, taking responsibility for advising Starmer on the appointment despite Mandelson's past association with convicted sex offender Jeffrey Epstein. Tim Allan, Starmer's director of communications, followed suit shortly thereafter. Officials cited by British media said cabinet ministers were also preparing to privately urge Starmer to resign or threaten their own departures. On Feb. 9, Scottish Labour leader Anas Sarwar publicly called for Starmer's resignation, becoming the most senior Labour figure to do so. At least for now, however, Starmer maintains the public support of senior government members, including those U.K. media have identified as potential contenders for Labour Party leadership, such as Former Deputy Prime Minister Angela Rayner, Health Secretary Wes Streeting, Home Secretary Shabana Mahmood and Energy Secretary Ed Miliband.","overview":"","youtube_video_url":"","created":"1770752187","created_formatted":"Feb 10, 2026 | 19:36 GMT","changed":"1770752306","changed_formatted":"Feb 10, 2026 | 19:38 GMT","path_alias":"article/uk-starmers-leadership-struggles-reach-tipping-point","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"102","vid":"5","v_name":"countries","name":"United Kingdom","code":"GB","path_alias":"/region/europe/united-kingdom"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"102","vid":"5","name":"United Kingdom"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351972","type":"article","ntype":"worldview","title":"Economic Concessions to U.S. Offer Path for Regime Survival in Cuba","promo_image":{"uri":"public://GettyImages-2260228972.jpg","alt":"American Airlines planes sit on the tarmac at Jose Marti International Airport in Havana on Feb. 9, 2026. ","title":"American Airlines planes sit on the tarmac at Jose Marti International Airport in Havana on Feb. 9, 2026. ","caption":"American Airlines planes sit on the tarmac at Jose Marti International Airport in Havana on Feb. 9, 2026. ","credit":"(YAMIL LAGE/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2260228972.jpg?itok=-jmoWiDX","small":"16x9_small/public/GettyImages-2260228972.jpg?itok=5353kHUl","medium":"16x9_medium/public/GettyImages-2260228972.jpg?itok=2gja2f6S","large":"16x9_large/public/GettyImages-2260228972.jpg?itok=Li0IgqY-","full":"16x9_full/public/GettyImages-2260228972.jpg?itok=so9AwDdc"},"square":{"tiny":"square_tiny/public/GettyImages-2260228972.jpg?itok=MoWCH8yR","small":"square_small/public/GettyImages-2260228972.jpg?itok=oOeQQqaP","medium":"square_medium/public/GettyImages-2260228972.jpg?itok=SWdj_kqQ","large":"square_large/public/GettyImages-2260228972.jpg?itok=_Iuw4E5g","full":"square_full/public/GettyImages-2260228972.jpg?itok=5_sd8lXR"},"article":{"tiny":"article_tiny/public/GettyImages-2260228972.jpg?itok=aOgmjH_l","small":"article_small/public/GettyImages-2260228972.jpg?itok=ykVI-RHl","medium":"article_medium/public/GettyImages-2260228972.jpg?itok=aIgO_PTk","large":"article_large/public/GettyImages-2260228972.jpg?itok=uhZIpEWl","full":"article_full/public/GettyImages-2260228972.jpg?itok=1Oqfi0n-"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2260228972.jpg?itok=G_aE7MGI","small":"2x1_small/public/GettyImages-2260228972.jpg?itok=lHSgB0gs","medium":"2x1_medium/public/GettyImages-2260228972.jpg?itok=k0elTWVc","large":"2x1_large/public/GettyImages-2260228972.jpg?itok=5fHCHHd8","full":"2x1_full/public/GettyImages-2260228972.jpg?itok=pLyr6qVF"}}},"teaser_body":"Facing imminent economic collapse and the loss of key allies, the Cuban government will likely yield to U.S. demands for market liberalization to avoid a total breakdown of state authority while attempting to preserve political control.","pov":"","mailout":"Facing imminent collapse and mounting U.S. pressure, the Cuban government will likely make concessions to Washington to gradually open its economy without requiring structural political changes, which the United States will likely support to avoid a state collapse and reaffirm its geopolitical dominance in the Western Hemisphere.","overview":"","youtube_video_url":"","created":"1770749346","created_formatted":"Feb 10, 2026 | 18:49 GMT","changed":"1770826465","changed_formatted":"Feb 11, 2026 | 16:14 GMT","path_alias":"article/economic-concessions-us-offer-path-regime-survival-cuba","article_type":{"tid":"502","vid":"30","name":"Assessments"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"39","vid":"5","v_name":"countries","name":"Cuba","code":"CU","path_alias":"/region/americas/cuba"},{"tid":"49","vid":"5","v_name":"countries","name":"Mexico","code":"MX","path_alias":"/region/americas/mexico"},{"tid":"59","vid":"5","v_name":"countries","name":"United States","code":"US","path_alias":"/region/americas/united-states"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"526","vid":"33","v_name":"wv_topics","name":"Energy","path_alias":"/topic/energy"},{"tid":"529","vid":"33","v_name":"wv_topics","name":"Military \u0026 Security","path_alias":"/topic/military-security"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"39","vid":"5","name":"Cuba"},{"tid":"49","vid":"5","name":"Mexico"},{"tid":"59","vid":"5","name":"United States"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"526","vid":"33","name":"Energy"},{"tid":"529","vid":"33","name":"Military \u0026 Security"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351968","type":"article","ntype":"worldview","title":"Election Landslide Stabilizes Japanese Politics, Cements Defense Modernization","promo_image":{"uri":"public://GettyImages-2259987841.jpg","alt":"Japanese Prime Minister and President of the Liberal Democratic Party (LDP) Sanae Takaichi reacts as she speaks with media on the day of lower house elections at the LDP headquarters in Tokyo on Feb. 8, 2026. ","title":"Japanese Prime Minister and President of the Liberal Democratic Party (LDP) Sanae Takaichi reacts as she speaks with media on the day of lower house elections at the LDP headquarters in Tokyo on Feb. 8, 2026. ","caption":"Japanese Prime Minister and President of the Liberal Democratic Party (LDP) Sanae Takaichi reacts as she speaks with media on the day of lower house elections at the LDP headquarters in Tokyo on Feb. 8, 2026.","credit":"(Kim Kyung-Hoon / POOL / AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259987841.jpg?itok=y-L9LnM1","small":"16x9_small/public/GettyImages-2259987841.jpg?itok=mAo7WYNu","medium":"16x9_medium/public/GettyImages-2259987841.jpg?itok=tRRQojaz","large":"16x9_large/public/GettyImages-2259987841.jpg?itok=opyMYmJ2","full":"16x9_full/public/GettyImages-2259987841.jpg?itok=I7p-D2Qe"},"square":{"tiny":"square_tiny/public/GettyImages-2259987841.jpg?itok=I1aZSLR9","small":"square_small/public/GettyImages-2259987841.jpg?itok=A4F5ut0i","medium":"square_medium/public/GettyImages-2259987841.jpg?itok=07fwFraz","large":"square_large/public/GettyImages-2259987841.jpg?itok=wqAXeEm1","full":"square_full/public/GettyImages-2259987841.jpg?itok=bicXIZC1"},"article":{"tiny":"article_tiny/public/GettyImages-2259987841.jpg?itok=rv6UY8vu","small":"article_small/public/GettyImages-2259987841.jpg?itok=c-KjrKL6","medium":"article_medium/public/GettyImages-2259987841.jpg?itok=dlPftPmK","large":"article_large/public/GettyImages-2259987841.jpg?itok=2WFgd2LC","full":"article_full/public/GettyImages-2259987841.jpg?itok=2BHBkOKC"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2259987841.jpg?itok=4hfCDB6u","small":"2x1_small/public/GettyImages-2259987841.jpg?itok=f3Vz0Kyf","medium":"2x1_medium/public/GettyImages-2259987841.jpg?itok=F3fy19tC","large":"2x1_large/public/GettyImages-2259987841.jpg?itok=u8hLEU0B","full":"2x1_full/public/GettyImages-2259987841.jpg?itok=RZySD0-g"}}},"teaser_body":"The LDP's decisive lower house victory will enable Prime Minister Takaichi to boost social and defense spending and strengthen ties with the U.S., though at the expense of Japan’s relations with China and South Korea.","pov":"","mailout":"A major electoral victory by Japan's ruling party will enable conservative Prime Minister Sanae Takaichi to expand social and defense spending, ease lingering concerns about political instability and bolster ties with the United States, though at the expense of those with China and potentially South Korea. Takaichi's ruling Liberal Democratic Party (LDP) won 316 out of 465 seats in the Feb. 8 snap elections for the lower house of the Diet, giving it a rare supermajority and the largest seat share in its party history. When combined with its coalition partner, the Japan Innovation Party, the LDP-led government now has 352 seats. Opposition parties, on the other hand, heavily underperformed. The main opposition Centrist Reform Alliance (CRA) -- formed in recent weeks by a merger of the center-left Constitutional Democratic Party and former LDP coalition partner, the center-left Komeito -- saw its seat count drop from 167 to just 49. Other opposition parties across the political spectrum also generally underperformed, with the exception of the right-wing nativist party Sanseito, which rose from two to 15 seats. The Diet will convene a special session on Feb. 18 to vote on the next prime minister, which Takaichi is guaranteed to win. The session will also hand control of the powerful lower house standing committees to the LDP and belatedly commence work on the 2026 budget, which is due by March 31.","overview":"","youtube_video_url":"","created":"1770676588","created_formatted":"Feb 9, 2026 | 22:36 GMT","changed":"1770676588","changed_formatted":"Feb 9, 2026 | 22:36 GMT","path_alias":"article/election-landslide-stabilizes-japanese-politics-cements-defense-modernization","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"200","vid":"5","v_name":"countries","name":"Japan","code":"JP","path_alias":"/region/asia-pacific/japan"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"200","vid":"5","name":"Japan"}],"wv_topics":[{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351958","type":"article","ntype":"worldview","title":"In Tunisia, UGTT Infighting Risks Playing Into President Saied's Hands","promo_image":{"uri":"public://GettyImages-2230479411.jpg","alt":"Supporters of Tunisia's General Labour Union (UGTT) wave the national flag during a rally in Tunis on Aug. 21, 2025.","title":"Supporters of Tunisia's General Labour Union (UGTT) wave the national flag during a rally in Tunis on Aug. 21, 2025.","caption":"Supporters of Tunisia's General Labour Union (UGTT) wave the national flag during a rally in Tunis on Aug. 21, 2025.","credit":"(FETHI BELAID/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2230479411.jpg?itok=7Q6OnFaI","small":"16x9_small/public/GettyImages-2230479411.jpg?itok=zZ5mgjsU","medium":"16x9_medium/public/GettyImages-2230479411.jpg?itok=sIX6jTBC","large":"16x9_large/public/GettyImages-2230479411.jpg?itok=ZrYuLuL7","full":"16x9_full/public/GettyImages-2230479411.jpg?itok=ikeg2Xw6"},"square":{"tiny":"square_tiny/public/GettyImages-2230479411.jpg?itok=_YjxNxQ1","small":"square_small/public/GettyImages-2230479411.jpg?itok=9VmsttyC","medium":"square_medium/public/GettyImages-2230479411.jpg?itok=SbU5LHSe","large":"square_large/public/GettyImages-2230479411.jpg?itok=nMqRLtK9","full":"square_full/public/GettyImages-2230479411.jpg?itok=kWqdEfGc"},"article":{"tiny":"article_tiny/public/GettyImages-2230479411.jpg?itok=Rbuvv2V2","small":"article_small/public/GettyImages-2230479411.jpg?itok=uJQc_3XU","medium":"article_medium/public/GettyImages-2230479411.jpg?itok=pIokp_9r","large":"article_large/public/GettyImages-2230479411.jpg?itok=aIORQCU_","full":"article_full/public/GettyImages-2230479411.jpg?itok=uGxCiXvq"},"2x1":{"tiny":"2x1_tiny/public/GettyImages-2230479411.jpg?itok=CjKjlwEv","small":"2x1_small/public/GettyImages-2230479411.jpg?itok=kwVLxLf5","medium":"2x1_medium/public/GettyImages-2230479411.jpg?itok=W5YOeM2f","large":"2x1_large/public/GettyImages-2230479411.jpg?itok=9lViFEbT","full":"2x1_full/public/GettyImages-2230479411.jpg?itok=NH-EsFKW"}}},"teaser_body":"If the UGTT fails to resolve internal disputes and stage an effective national strike, President Saied will likely launch an expanded crackdown that further weakens the powerful labor union and, consequently, its private-sector bargaining power.","pov":"","mailout":"In Tunisia, officials from the country's influential labor union confederation will likely try to mend internal disputes to increase the effectiveness of any rescheduled national strike, but failure to do so would likely embolden Tunisian President Kais Saied to further erode the union's strength and, in turn, private-sector bargaining power. Nearly three weeks have passed since the Tunisian General Labor Union, or UGTT, had originally intended to conduct a nationwide general strike on Jan. 21. On Jan. 23, the union's deputy secretary-general suggested that a decision regarding the future of the strike would be determined at the union's congress, tentatively scheduled for March 25-27. Union leadership originally called for the strike in December 2025 to protest the Tunisian government's crackdown on the opposition, protect the union's right to collective bargaining after the central government sidelined the union from wage and pension increase negotiations, and call for dialogue between government and union leaders. The decision to postpone the strike came amid internal disputes and uncertainty over union leadership following several officials' resignations. Most notably, Nourreddine Taboubi, the secretary-general, submitted his resignation on Dec. 23 but later withdrew it on Jan. 13, in what some critics alleged was a calculated move to pressure union leaders ahead of the legal deadline to call off a strike. Taboubi's resignation elevated concerns among union officials that the change in leadership -- particularly ahead of a planned nationwide strike -- risked deeper fragmentation and could fuel internal divisions.","overview":"","youtube_video_url":"","created":"1770665104","created_formatted":"Feb 9, 2026 | 19:25 GMT","changed":"1770665104","changed_formatted":"Feb 9, 2026 | 19:25 GMT","path_alias":"article/tunisia-ugtt-infighting-risks-playing-president-saieds-hands","article_type":{"tid":"505","vid":"30","name":"Snapshots"},"assessments_type":[],"column_type":[],"media_type":[],"global_perspectives_type":[],"sectioned_content_type":[],"forecast_type":[],"www_public_postings_type":[],"source":"","www_site_page_type":[],"taxonomy":[{"tid":"188","vid":"5","v_name":"countries","name":"Tunisia","code":"TN","path_alias":"/region/middle-east-and-north-africa/tunisia"},{"tid":"528","vid":"33","v_name":"wv_topics","name":"Economics","path_alias":"/topic/economics"},{"tid":"530","vid":"33","v_name":"wv_topics","name":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":1,"countries":[{"tid":"188","vid":"5","name":"Tunisia"}],"wv_topics":[{"tid":"528","vid":"33","name":"Economics"},{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351951","type":"article","ntype":"worldview","title":"What To Expect From Bangladesh's Upcoming Elections","promo_image":{"uri":"public://Decision_Advantage_Draft_Logo_4bk7hl.png","alt":"The Decision Advantage RANE Podcast","title":"","caption":"","credit":"(RANE)","sizes":{"16x9":{"tiny":"16x9_tiny/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=GKkyDOwk","small":"16x9_small/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=zgG5wqsi","medium":"16x9_medium/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=BObFpCwf","large":"16x9_large/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=heGglv-9","full":"16x9_full/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=uZ_PmNG-"},"square":{"tiny":"square_tiny/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=3nDFEoal","small":"square_small/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=RzYNC4f6","medium":"square_medium/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=n4V6I0Bn","large":"square_large/public/Decision_Advantage_Draft_Logo_4bk7hl.png?itok=Cchdv_Au",