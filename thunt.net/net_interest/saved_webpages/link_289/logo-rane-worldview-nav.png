":"Politics","path_alias":"/topic/politics"}],"author":[],"pdf":"","status":1,"premium":0,"countries":[{"tid":"116","vid":"5","name":"Bangladesh"}],"wv_topics":[{"tid":"530","vid":"33","name":"Politics"}],"is_bookmarked":0},{"nid":"351939","type":"article","ntype":"worldview","title":"The Weekly Rundown: Japan Holds Snap Elections, U.S. Weighs Options After Iran Talks","promo_image":{"uri":"public://GettyImages-2259572154.jpg","alt":"Campaign posters Feb. 6 of candidates running in the upcoming Japanese House of Representatives election, in Inagi, Tokyo prefecture.","title":"Campaign posters Feb. 6 of candidates running in the upcoming Japanese House of Representatives election, in Inagi, Tokyo prefecture.","caption":"Campaign posters Feb. 6 of candidates running in the upcoming Japanese House of Representatives election, in Inagi, Tokyo prefecture.","credit":"(Yuichi YAMAZAKI/AFP via Getty Images)","sizes":{"16x9":{"tiny":"16x9_tiny/public/GettyImages-2259572154.jpg?itok=ZXSZ5wo2","small":"16x9_small/public/GettyImages-2259572154.jpg?itok=F0Ru79YU","medium":"16x9_medium/public/GettyImages-2259572154.jpg?itok=D6U8ewu9","large":"16x9_large/public/GettyImages-2259572154.jpg?itok=ZvRkuh42","full":"16x9_full/public/GettyImages-2259572154.jpg?itok=DY8ST9TU"},"square":{"tiny":"square_tiny/public/GettyImages-2259572154.jpg?itok=WeZzGMyB","small":"square_small/public/GettyImages-2259572154.jpg?itok=wFa_swX-","medium":"square_medium/public/GettyImages-2259572154.jpg?itok=u3ZGAEXS","large":"square_large/public/GettyImages-2259572154.jpg?itok=jAKXjIfT","full":"square_full/public/GettyImages-2259572154.jpg?itok=M__qwY5V"},"article":{"tiny":"article_tiny/public/GettyImages-2259572154.jpg?itok=VgytrZAT","small":"article_small/public/GettyImages-2259572154.jpg?itok=sLoXacxF","medium":"article_medium/public/GettyImages-2259572154.jpg?itok=m7SO6im5","large":"article_large/public/GettyImages-2259572154.jpg?itok=Q1MPaGC_","full":"article_full/public/GettyImages-2259572154.jpg?itok=Bk-